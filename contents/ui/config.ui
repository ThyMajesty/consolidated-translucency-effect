    <resources/>
    <connections>
        <!-- Fullscreen override toggles sliders -->
        <connection>
            <sender>kcfg_FullscreenOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_FullscreenActive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <connection>
            <sender>kcfg_FullscreenOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_FullscreenInactive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <!-- Dialogs override toggles sliders -->
        <connection>
            <sender>kcfg_DialogsOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_DialogsActive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
