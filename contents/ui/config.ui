        <connection>
            <sender>kcfg_NotificationsOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_NotificationsInactive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <!-- MoveResize override toggles slider -->
        <connection>
            <sender>kcfg_MoveResizeOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_MoveResizeOpacity</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <!-- Dock override toggles sliders -->
        <connection>
            <sender>kcfg_DockOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_DockActive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <connection>
            <sender>kcfg_DockOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_DockInactive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <!-- Desktop override toggles sliders -->
        <connection>
            <sender>kcfg_DesktopOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_DesktopActive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <connection>
            <sender>kcfg_DesktopOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_DesktopInactive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <!-- Unmanaged override toggles sliders -->
        <connection>
            <sender>kcfg_UnmanagedOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_UnmanagedActive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
        <connection>
            <sender>kcfg_UnmanagedOverride</sender>
            <signal>toggled(bool)</signal>
            <receiver>kcfg_UnmanagedInactive</receiver>
            <slot>setEnabled(bool)</slot>
        </connection>
    </connections>
</ui>
